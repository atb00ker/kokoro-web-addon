# Kokoro Web — local environment variables
#
# Copy to .env (gitignored):
#   cp .env.example .env
#
# Further documentation (read these instead of duplicating detail here):
#   docs/SETUP.md             — variable reference, GitHub repository secrets, CI environments, first release
#   docs/DEV.md               — day-to-day development and releasing
#
# Pre-filled identity values below are public dev defaults. Local development
# works without editing them. Override only when forking or using different IDs.

# Native messaging host identifier (reverse-DNS string, not a network hostname).
# kokoro-web-setup writes browser manifests named {KOKORO_HOST_NAME}.json; the
# extension connects to the same ID (src/extension/lib/defaults.ts). Always local.
# Default is fine for normal use — change only if you fork with a different ID.
# Also set as a GitHub repository secret for release CI. See docs/SETUP.md.
KOKORO_HOST_NAME=com.kokoro.web

# Firefox add-on ID (manifest browser_specific_settings.gecko.id).
# Shown on AMO after first listing; also used by kokoro-web-setup for Firefox.
# Pre-filled default — keep unless you publish under a different AMO account/ID.
# Obtain: choose at first AMO submission — see docs/SETUP.md#first-release.
# Also set as a GitHub repository secret. See docs/SETUP.md.
FIREFOX_EXTENSION_ID=kokoro-web@atb00ker

# Chrome extension ID — must match the ID pinned by CHROME_MANIFEST_KEY below.
# kokoro-web-setup embeds this in Chrome native-messaging allowed_origins.
# Verify after build: chrome://extensions → load .output/chrome-mv3/ → check ID.
# Regenerating the key pair: docs/SETUP.md; paired private key is chrome-key.pem (gitignored).
# Also set as a GitHub repository secret. See docs/SETUP.md.
CHROME_EXTENSION_ID=pkfapjbdbhkoohckjmlbloocjnlfmklk

# Base64-encoded RSA public key written to the Chrome manifest as "key".
# Pins CHROME_EXTENSION_ID so store builds keep a stable ID for native messaging.
# Paired private key: chrome-key.pem (gitignored). Do not commit the private key.
# Regenerating: docs/SETUP.md or npx wxt submit init. Also a GitHub repository secret.
CHROME_MANIFEST_KEY=MFwwDQYJKoZIhvcNAQEBBQADSwAwSAJBAKGoJ7hFzKy768eb8RpeOp496nlYF+X600DgB+TJOyeuB3Sk42YsD/p9b9cuGRsfygZB12DIyOTshs81tDCLP0cCAwEAAQ==

# --- Store publish credentials (optional locally; required for wxt submit dry-runs) ---
# CI reads these from GitHub Environments (firefox / chrome), not from .env.
# Leave blank unless testing store uploads locally. Never commit filled values.

# Firefox AMO API JWT credentials for automated extension updates.
# Obtain: https://addons.mozilla.org/developers/addon/api/key/
#   or run: npx wxt submit init  → copy from .env.submit (do not commit .env.submit)
# GitHub: Firefox environment secrets. See docs/SETUP.md
FIREFOX_JWT_ISSUER=
FIREFOX_JWT_SECRET=

# Chrome Web Store API OAuth credentials for automated extension updates.
# Obtain: https://github.com/fregante/chrome-webstore-upload-keys
#   or run: npx wxt submit init  → copy from .env.submit (do not commit .env.submit)
# GitHub: Chromium environment secrets. See docs/SETUP.md
CHROME_CLIENT_ID=
CHROME_CLIENT_SECRET=
CHROME_REFRESH_TOKEN=
