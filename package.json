{
  "name": "kokoro-web",
  "version": "0.1.1",
  "private": true,
  "description": "Browser extension for Kokoro Web via native messaging",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build && wxt build -b chrome",
    "zip": "wxt zip && wxt zip -b chrome",
    "postinstall": "wxt prepare",
    "typecheck": "wxt prepare && tsc --noEmit",
    "format": "prettier --write src",
    "lint": "eslint src --fix && prettier --check src && npm run typecheck",
    "test": "bun run test:unit && bun run test:mocked",
    "test:unit": "bun test src/extension --path-ignore-patterns '**/session-manager.test.ts'",
    "test:mocked": "bun test --isolate src/extension/lib/session-manager.test.ts src/extension/lib/synthesis/playback-pipeline.test.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/bun": "^1.3.14",
    "@types/node": "^22.20.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "prettier": "^3.9.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.1",
    "wxt": "^0.20.27"
  }
}
